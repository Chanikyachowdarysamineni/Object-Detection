# ============================================================================
# ENVIRONMENT CONFIGURATION - SECURITY BEST PRACTICES
# ============================================================================
# 
# IMPORTANT: Never commit actual secrets to version control!
# Use .env files for local development only.
# In production, use environment variables from your deployment platform.
#
# For production setup, run: bash setup-security.sh
#
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================

# Set to 'development' or 'production'
# CRITICAL: Must be 'production' in production environment
ENVIRONMENT=development

# Enable debug mode (NEVER true in production!)
DEBUG=true

# ============================================================================
# SECRET KEY - CRITICAL SECURITY
# ============================================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit the real key to version control!
SECRET_KEY=your-secret-key-change-this-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DATABASE_URL=postgresql://postgres:password@localhost:5432/detections_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
API_TITLE=Object Detection API
API_VERSION=1.0.0

# ============================================================================
# SECURITY - CORS & ORIGINS
# ============================================================================

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# SECURITY HEADERS (Production only)
# ============================================================================

SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# ============================================================================
# GRADIO CONFIGURATION (Optional)
# ============================================================================

GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860
GRADIO_SHARE=False

# ============================================================================
# YOLOV8 CONFIGURATION
# ============================================================================

MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45
IMAGE_SIZE=640
MAX_DETECTIONS=100
DEVICE=0

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ============================================================================
# UPLOAD & PROCESSING LIMITS
# ============================================================================

MAX_UPLOAD_SIZE=104857600
MAX_IMAGE_SIZE=52428800
MAX_VIDEO_SIZE=524288000
REQUEST_TIMEOUT=300
BATCH_SIZE=16
NUM_WORKERS=4

# ============================================================================
# CLOUD STORAGE (Cloudinary - Optional)
# ============================================================================

ENABLE_CLOUDINARY=false
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# AWS Secrets Manager
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# DataDog APM
DATADOG_APM_ENABLED=false
DATADOG_API_KEY=your-api-key

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to production:
#
# 1. [ ] Copy .env.example to .env.production
# 2. [ ] Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 3. [ ] Set ENVIRONMENT=production
# 4. [ ] Set DEBUG=false
# 5. [ ] Update DATABASE_URL with production database
# 6. [ ] Configure ALLOWED_ORIGINS with production domain
# 7. [ ] Set chmod 600 .env.production (owner read/write only)
# 8. [ ] Store in secure location (not in git!)
# 9. [ ] Configure SSL/TLS certificates
# 10. [ ] Enable security headers and rate limiting
#
# ============================================================================

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:7860", "http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Processing
MAX_UPLOAD_SIZE=104857600  # 100MB
BATCH_SIZE=16
NUM_WORKERS=4

# Features
ENABLE_TRAINING=True
ENABLE_EXPORT=True
ENABLE_CLOUDINARY=False
